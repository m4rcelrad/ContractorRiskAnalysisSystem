@page "/"
@using CRAS.Domain.Enums
@using CRAS.Application.Models
@using CRAS.Domain.Models
@using CRAS.Web.Services
@inject DashboardStateService DashboardState

<PageTitle>Risk Dashboard</PageTitle>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Risk Intelligence Dashboard</h2>
            <span class="text-muted small">Real-time contractor financial assessment</span>
        </div>
        <button class="btn btn-dark px-4 rounded-pill shadow-sm" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise me-2"></i> Refresh Analysis
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger rounded-3 shadow-sm border-0 border-start border-danger border-5">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>System Error:</strong> @_errorMessage
        </div>
    }
    else if (DashboardState.Overviews == null)
    {
        <div class="d-flex flex-column justify-content-center align-items-center" style="min-height: 40vh;">
            <div class="spinner-grow text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted fw-semibold">Analyzing financial statements...</p>
        </div>
    }
    else if (!DashboardState.Overviews.Any())
    {
        <div class="alert alert-info rounded-3 shadow-sm border-0 text-center p-5">
            <i class="bi bi-inbox text-info" style="font-size: 3rem;"></i>
            <h4 class="mt-3">No Data Available</h4>
            <p class="mb-0">Run the seeder or connect to the database to view risk assessments.</p>
        </div>
    }
    else
    {
        <div class="row mb-5">
            <div class="col-md-3">
                <div class="card summary-card shadow-sm bg-primary text-white h-100 position-relative overflow-hidden">
                    <div class="card-body">
                        <h6 class="text-uppercase fw-semibold mb-1 opacity-75">Total Assessed</h6>
                        <h2 class="fw-bold mb-0">@DashboardState.Overviews.Count</h2>
                        <i class="bi bi-buildings-fill summary-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card summary-card shadow-sm bg-success text-white h-100 position-relative overflow-hidden">
                    <div class="card-body">
                        <h6 class="text-uppercase fw-semibold mb-1 opacity-75">Safe Status</h6>
                        <h2 class="fw-bold mb-0">@DashboardState.Overviews.Count(c => c.Assessment.OverallRisk == RiskLevel.Safe)</h2>
                        <i class="bi bi-shield-check summary-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card summary-card shadow-sm bg-warning text-dark h-100 position-relative overflow-hidden">
                    <div class="card-body">
                        <h6 class="text-uppercase fw-semibold mb-1 opacity-75">Monitoring Required</h6>
                        <h2 class="fw-bold mb-0">@DashboardState.Overviews.Count(c => c.Assessment.OverallRisk == RiskLevel.Grey)</h2>
                        <i class="bi bi-eye-fill summary-icon text-dark"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card summary-card shadow-sm bg-danger text-white h-100 position-relative overflow-hidden">
                    <div class="card-body">
                        <h6 class="text-uppercase fw-semibold mb-1 opacity-75">High Risk / Distress</h6>
                        <h2 class="fw-bold mb-0">@DashboardState.Overviews.Count(c => c.Assessment.OverallRisk == RiskLevel.Distress)</h2>
                        <i class="bi bi-exclamation-octagon-fill summary-icon"></i>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="fw-bold mb-3">Individual Contractor Reports</h5>
        <div class="row g-4">
            @foreach (var item in DashboardState.Overviews.OrderByDescending(c => c.Assessment.OverallRisk))
            {
                <div class="col-xxl-3 col-xl-4 col-lg-4 col-md-6">
                    <div class="card risk-card shadow-sm border-0 border-top border-5 border-@GetStatusColor(item.Assessment.OverallRisk) h-100">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="text-muted small text-uppercase fw-bold">Tax ID</span>
                                    <h5 class="fw-bold mb-0">@item.TaxId</h5>
                                </div>
                                <span class="badge bg-@GetStatusColor(item.Assessment.OverallRisk) rounded-pill px-3 py-2">
                                    @GetRiskIcon(item.Assessment.OverallRisk) @item.Assessment.OverallRisk
                                </span>
                            </div>

                            <div class="flex-grow-1 bg-light rounded-3 p-3 mb-3">
                                <h6 class="small fw-bold text-uppercase text-muted mb-3">Model Breakdown</h6>
                                <div class="d-flex flex-column gap-3">
                                    @foreach (var result in item.Assessment.Breakdown)
                                    {
                                        <div>
                                            <div class="d-flex justify-content-between align-items-end mb-1">
                                                <span class="text-dark fw-medium" style="font-size: 0.85rem;">@result.Model</span>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="fw-bold" style="font-size: 0.85rem;">@result.Score.ToString("F2")</span>
                                                    <span class="badge bg-@GetStatusColor(result.RiskLevel)-subtle text-@GetStatusColor(result.RiskLevel) border border-@GetStatusColor(result.RiskLevel)" style="font-size: 0.65rem;">
                                                        @result.RiskLevel
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="mt-auto">
                                <a href="/contractors/@item.ContractorId" class="btn btn-outline-@GetStatusColor(item.Assessment.OverallRisk) w-100 rounded-pill fw-semibold">
                                    View Full Report
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task RefreshData()
    {
        _errorMessage = null;
        await LoadDashboardData(true);
    }

    private async Task LoadDashboardData(bool force = false)
    {
        try
        {
            await DashboardState.LoadDataAsync(force);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private static string GetStatusColor(RiskLevel level) => level switch
    {
        RiskLevel.Safe => "success",
        RiskLevel.Grey => "warning",
        RiskLevel.Distress => "danger",
        _ => "secondary"
    };

    private static string GetRiskIcon(RiskLevel level) => level switch
    {
        RiskLevel.Safe => "✓",
        RiskLevel.Grey => "⚠",
        RiskLevel.Distress => "✕",
        _ => "•"
    };
}
