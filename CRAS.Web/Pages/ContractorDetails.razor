@page "/contractors/{Id:guid}"
@using System.Net
@using System.Text.Json
@using System.Text.Json.Serialization
@using CRAS.Application.Models
@using CRAS.Domain.Entities
@using CRAS.Domain.Enums
@using CRAS.Domain.Interfaces
@using CRAS.Domain.Models
@inject HttpClient Http
@inject IRatioCalculator RatioCalculator
@inject IPaymentAnalyzer PaymentAnalyzer

<PageTitle>Contractor Report</PageTitle>

<div class="container-fluid mt-4 px-4">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a href="/" class="text-decoration-none text-muted mb-2 d-inline-block">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
            <h2 class="fw-bold mb-0">
                Contractor Report
                @if (_contractor != null)
                {
                    <span class="text-primary">#@_contractor.TaxId</span>
                }
            </h2>
        </div>
        @if (_assessment != null)
        {
            <div class="text-end d-flex align-items-center gap-3">
                <a href="@($"http://localhost:5250/api/contractors/{Id}/report")" target="_blank"
                   class="btn btn-outline-primary rounded-pill px-4 py-2 shadow-sm">
                    <i class="bi bi-file-earmark-pdf-fill me-2"></i> Download Report
                </a>

                <div>
                    <span class="text-muted small d-block text-uppercase fw-bold">Overall Status</span>
                    <span
                        class="badge bg-@GetStatusColor(_assessment.OverallRisk) fs-5 px-4 py-2 rounded-pill shadow-sm">
                        @_assessment.OverallRisk
                    </span>
                </div>
            </div>
        }
    </div>

    @switch (_state)
    {
        case PageState.Error:
            <div class="alert alert-danger rounded-3 shadow-sm border-0 border-start border-danger border-5 mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>System Error:</strong> @_errorMessage
            </div>
            break;
        case PageState.Loading:
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
            break;
        case PageState.Ready when _contractor != null && _assessment != null:
        {
            var latestStatement = _contractor.FinancialStatements.OrderByDescending(s => s.Year).FirstOrDefault();

            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-0 pt-4 pb-0">
                            <h6 class="fw-bold text-uppercase text-muted mb-0">Risk Models Assessment</h6>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                @foreach (var result in _assessment.Breakdown)
                                {
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 mb-2">
                                        <div>
                                            <span class="fw-bold d-block">@result.Model</span>
                                            <span class="text-muted small">Score: @result.Score.ToString("F3")</span>
                                        </div>
                                        <span
                                            class="badge bg-@GetStatusColor(result.RiskLevel)-subtle text-@GetStatusColor(result.RiskLevel) border border-@GetStatusColor(result.RiskLevel) px-3 py-2">
                                            @result.RiskLevel
                                        </span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>

                @if (latestStatement != null && _ratios != null)
                {
                    <div class="col-lg-8">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-white border-0 pt-4 pb-0">
                                <h6 class="fw-bold text-uppercase text-muted mb-0">Key Financial Ratios
                                    (@latestStatement.Year)</h6>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <div class="p-3 bg-light rounded-3">
                                            <span class="text-muted small text-uppercase fw-bold">Current Ratio</span>
                                            <h3 class="mb-0 text-dark">@_ratios.CurrentRatio.ToString("F2")</h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3 bg-light rounded-3">
                                            <span class="text-muted small text-uppercase fw-bold">Debt Ratio</span>
                                            <h3 class="mb-0 text-dark">@_ratios.DebtRatio.ToString("P1")</h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3 bg-light rounded-3">
                                            <span
                                                class="text-muted small text-uppercase fw-bold">Return on Equity</span>
                                            <h3 class="mb-0 text-dark">@_ratios.ReturnOnEquity.ToString("P1")</h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3 bg-light rounded-3">
                                            <span class="text-muted small text-uppercase fw-bold">Working Capital / Assets</span>
                                            <h3 class="mb-0 text-dark">@_ratios.WorkingCapitalToAssets.ToString("P1")</h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3 bg-light rounded-3">
                                            <span class="text-muted small text-uppercase fw-bold">Asset Turnover</span>
                                            <h3 class="mb-0 text-dark">@_ratios.AssetTurnover.ToString("F2")</h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3 bg-light rounded-3">
                                            <span class="text-muted small text-uppercase fw-bold">EBIT Margin</span>
                                            <h3 class="mb-0 text-dark">@_ratios.EbitMargin.ToString("P1")</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (_contractor.Invoices.Any() && _paymentMetrics != null)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-uppercase text-muted mb-0">Payment Behavior</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-muted small text-uppercase fw-bold">Average Delay</span>
                                    <h3 class="mb-0 text-@(_paymentMetrics.AverageDelayDays > 14 ? "danger" : _paymentMetrics.AverageDelayDays > 0 ? "warning" : "success")">
                                        @Math.Max(0, Math.Round(_paymentMetrics.AverageDelayDays, 1)) days
                                    </h3>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-muted small text-uppercase fw-bold">Unpaid Invoices</span>
                                    <div class="d-flex align-items-baseline gap-2">
                                        <h3 class="mb-0 text-@(_paymentMetrics.UnpaidCount > 0 ? "danger" : "success")">@_paymentMetrics.UnpaidCount</h3>
                                        <span class="text-muted fw-semibold">
                                            (@_paymentMetrics.UnpaidRatio.ToString("P1"))
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-muted small text-uppercase fw-bold">Unpaid Amount</span>
                                    <h3 class="mb-0 text-@(_paymentMetrics.TotalUnpaidAmount > 0 ? "danger" : "success")">@_paymentMetrics.TotalUnpaidAmount.ToString("N0")</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <h6 class="fw-bold text-uppercase text-muted mb-0">Financial Statement History</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-muted small text-uppercase">
                            <tr>
                                <th>Year</th>
                                <th>Total Assets</th>
                                <th>Total Liabilities</th>
                                <th>Working Capital</th>
                                <th>EBIT</th>
                                <th>Sales</th>
                                <th>Net Income</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var statement in _contractor.FinancialStatements.OrderByDescending(s => s.Year))
                            {
                                <tr>
                                    <td class="fw-bold">@statement.Year</td>
                                    <td>@statement.TotalAssets.ToString("N0")</td>
                                    <td>@statement.TotalLiabilities.ToString("N0")</td>
                                    <td>@statement.WorkingCapital.ToString("N0")</td>
                                    <td>@statement.EBIT.ToString("N0")</td>
                                    <td>@statement.Sales.ToString("N0")</td>
                                    <td class="fw-semibold text-@(statement.NetIncome >= 0 ? "success" : "danger")">
                                        @statement.NetIncome.ToString("N0")
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            break;
        }
        default:
            throw new ArgumentOutOfRangeException();
    }
</div>

@code {

    private enum PageState
    {
        Loading,
        Ready,
        Error
    }

    [Parameter] public Guid Id { get; set; }

    private PageState _state = PageState.Loading;
    private Contractor? _contractor;
    private RiskAssessmentResponse? _assessment;
    private string? _errorMessage;
    private KeyFinancialRatios? _ratios;
    private PaymentBehaviorMetrics? _paymentMetrics;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true,
                Converters = { new JsonStringEnumConverter() }
            };

            _contractor = await Http.GetFromJsonAsync<Contractor>($"api/Contractors/{Id}", options);

            if (_contractor != null)
            {
                var latestStatement = _contractor.FinancialStatements.OrderByDescending(s => s.Year).FirstOrDefault();
                if (latestStatement != null)
                {
                    _ratios = RatioCalculator.CalculateFor(latestStatement);
                }

                _paymentMetrics = PaymentAnalyzer.Analyze(_contractor.Invoices.ToList());
            }

            try
            {
                _assessment = await Http.GetFromJsonAsync<RiskAssessmentResponse>($"api/Contractors/{Id}/assess", options);
            }
            catch (HttpRequestException ex) when (ex.StatusCode is HttpStatusCode.NotFound or HttpStatusCode.BadRequest)
            {
            }

            _state = PageState.Ready;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _state = PageState.Error;
        }
    }

    private static string GetStatusColor(RiskLevel level)
    {
        return level switch
        {
            RiskLevel.Low => "success",
            RiskLevel.Moderate => "warning",
            RiskLevel.Critical => "danger",
            _ => "secondary"
        };
    }

}
